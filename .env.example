# .env.example — copy to .env and fill in values

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Auth — comma-separated API keys for your college system
# Generate with: node -e "console.log(require('crypto').randomUUID())"
API_KEYS=your-secret-api-key-here,optional-second-key

# CORS — your college frontend origin(s)
CORS_ORIGINS=http://localhost:5173,https://your-college-portal.edu

# Rate limiting (requests per minute per IP)
RATE_LIMIT_PER_MIN=20

# Cache TTL in seconds (default 6 hours)
CACHE_TTL_SECONDS=21600

# Browser timeout in ms (default 30s)
BROWSER_TIMEOUT_MS=30000
